{
  "bundleId": "rhai-default-generic",
  "title": "Rhai VM / 外部板级固件",
  "runtimeKind": "RHAI_VM",
  "mcuFamily": "custom",
  "defaultFlashProfileId": "rhai-generic-serial",
  "defaultBaudRate": 115200,
  "artifactRelativePath": "artifacts/rhai-default-generic.bin",
  "resourceFiles": [
    "artifacts/rhai-default-generic.bin"
  ],
  "atomicCommands": [
    {
      "id": "gpio-set",
      "title": "GPIO 输出",
      "signature": "gpio_set(pin, value)",
      "description": "写入数字输出引脚",
      "exampleScript": "gpio_set(2, true);\ndelay_ms(120);\ngpio_set(2, false);"
    },
    {
      "id": "pwm-set",
      "title": "PWM 输出",
      "signature": "pwm_set(pin, duty)",
      "description": "设置 PWM 占空比",
      "exampleScript": "pwm_set(4, 512);\ndelay_ms(300);\npwm_set(4, 0);"
    },
    {
      "id": "adc-read",
      "title": "ADC 采样",
      "signature": "adc_read(pin)",
      "description": "读取模拟输入值",
      "exampleScript": "let value = adc_read(1);\nvalue"
    },
    {
      "id": "delay-ms",
      "title": "毫秒延时",
      "signature": "delay_ms(ms)",
      "description": "阻塞延时",
      "exampleScript": "delay_ms(250);"
    },
    {
      "id": "uart-send",
      "title": "串口发送",
      "signature": "uart_send(text)",
      "description": "向设备串口输出文本",
      "exampleScript": "uart_send(\"hello from kcloud\");"
    }
  ],
  "scriptExamples": [
    {
      "id": "blink-3x",
      "title": "三次闪灯",
      "description": "GPIO 输出示例",
      "language": "rhai",
      "script": "for _ in 0..3 {\n    gpio_set(2, true);\n    delay_ms(200);\n    gpio_set(2, false);\n    delay_ms(200);\n}"
    },
    {
      "id": "sensor-alarm",
      "title": "阈值报警",
      "description": "ADC + PWM 联动",
      "language": "rhai",
      "script": "let value = adc_read(1);\nif value > 600 {\n    pwm_set(4, 512);\n    delay_ms(150);\n    pwm_set(4, 0);\n}\nvalue"
    },
    {
      "id": "serial-ping",
      "title": "串口回显",
      "description": "调试输出",
      "language": "rhai",
      "script": "uart_send(\"ping from kcloud\");\n\"ping sent\""
    }
  ],
  "widgetTemplates": [
    {
      "id": "action-button",
      "title": "动作按钮",
      "description": "脉冲触发 GPIO",
      "kind": "ACTION_BUTTON",
      "scriptTemplate": "gpio_set({{pin}}, true);\ndelay_ms({{holdMs}});\ngpio_set({{pin}}, false);",
      "bindings": [
        {
          "key": "pin",
          "label": "Pin",
          "fieldKind": "INTEGER",
          "defaultValue": "2"
        },
        {
          "key": "holdMs",
          "label": "Hold(ms)",
          "fieldKind": "INTEGER",
          "defaultValue": "120"
        }
      ]
    },
    {
      "id": "boolean-switch",
      "title": "布尔开关",
      "description": "GPIO 开关控制",
      "kind": "BOOLEAN_SWITCH",
      "scriptTemplate": "gpio_set({{pin}}, {{enabled}});",
      "bindings": [
        {
          "key": "pin",
          "label": "Pin",
          "fieldKind": "INTEGER",
          "defaultValue": "2"
        },
        {
          "key": "enabled",
          "label": "Enabled",
          "fieldKind": "BOOLEAN",
          "defaultValue": "false"
        }
      ]
    },
    {
      "id": "pwm-slider",
      "title": "PWM 滑块",
      "description": "占空比调节",
      "kind": "PWM_SLIDER",
      "scriptTemplate": "pwm_set({{pin}}, {{duty}});",
      "bindings": [
        {
          "key": "pin",
          "label": "Pin",
          "fieldKind": "INTEGER",
          "defaultValue": "4"
        },
        {
          "key": "duty",
          "label": "Duty",
          "fieldKind": "NUMBER",
          "defaultValue": "512",
          "min": 0.0,
          "max": 1023.0,
          "step": 1.0
        }
      ]
    },
    {
      "id": "value-card",
      "title": "数值读取",
      "description": "ADC 单次采样",
      "kind": "VALUE_CARD",
      "scriptTemplate": "let value = adc_read({{pin}});\nvalue",
      "bindings": [
        {
          "key": "pin",
          "label": "Pin",
          "fieldKind": "INTEGER",
          "defaultValue": "1"
        }
      ]
    },
    {
      "id": "text-send",
      "title": "文本发送",
      "description": "串口发送文本",
      "kind": "TEXT_SEND",
      "scriptTemplate": "uart_send(\"{{text}}\");",
      "bindings": [
        {
          "key": "text",
          "label": "Text",
          "fieldKind": "TEXT",
          "defaultValue": "hello from kcloud"
        }
      ]
    }
  ]
}
