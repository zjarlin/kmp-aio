{
  "bundleId": "micropython-default-generic",
  "title": "MicroPython / ESP32 官方固件",
  "runtimeKind": "MICROPYTHON",
  "mcuFamily": "esp32",
  "defaultFlashProfileId": "micropython-generic-command",
  "defaultBaudRate": 115200,
  "artifactRelativePath": "artifacts/micropython-default-generic.bin",
  "resourceFiles": [
    "artifacts/micropython-default-generic.bin"
  ],
  "atomicCommands": [
    {
      "id": "pin-write",
      "title": "Pin 输出",
      "signature": "Pin(pin, Pin.OUT).value(value)",
      "description": "数字口写入",
      "exampleScript": "from machine import Pin\nPin(2, Pin.OUT).value(1)"
    },
    {
      "id": "pwm-duty",
      "title": "PWM 输出",
      "signature": "PWM(Pin(pin)).duty_u16(value)",
      "description": "PWM 占空比",
      "exampleScript": "from machine import Pin, PWM\npwm = PWM(Pin(4))\npwm.duty_u16(32768)"
    },
    {
      "id": "adc-read",
      "title": "ADC 采样",
      "signature": "ADC(Pin(pin)).read_u16()",
      "description": "模拟口读取",
      "exampleScript": "from machine import ADC, Pin\nvalue = ADC(Pin(1)).read_u16()\nprint(value)"
    }
  ],
  "scriptExamples": [
    {
      "id": "blink-basic",
      "title": "Pin 闪烁",
      "description": "基础脚本",
      "language": "micropython",
      "script": "from machine import Pin\nfrom time import sleep_ms\nled = Pin(2, Pin.OUT)\nfor _ in range(3):\n    led.value(1)\n    sleep_ms(200)\n    led.value(0)\n    sleep_ms(200)"
    },
    {
      "id": "uart-print",
      "title": "串口输出",
      "description": "文本日志",
      "language": "micropython",
      "script": "print('hello from kcloud micropython')"
    }
  ],
  "widgetTemplates": [
    {
      "id": "pin-switch",
      "title": "Pin 开关",
      "description": "数字输出切换",
      "kind": "BOOLEAN_SWITCH",
      "scriptTemplate": "from machine import Pin\nPin({{pin}}, Pin.OUT).value({{enabled}})",
      "bindings": [
        {
          "key": "pin",
          "label": "Pin",
          "fieldKind": "INTEGER",
          "defaultValue": "2"
        },
        {
          "key": "enabled",
          "label": "Enabled",
          "fieldKind": "BOOLEAN",
          "defaultValue": "false"
        }
      ]
    },
    {
      "id": "text-print",
      "title": "文本输出",
      "description": "print 文本",
      "kind": "TEXT_SEND",
      "scriptTemplate": "print(\"{{text}}\")",
      "bindings": [
        {
          "key": "text",
          "label": "Text",
          "fieldKind": "TEXT",
          "defaultValue": "hello from micropython"
        }
      ]
    }
  ]
}
