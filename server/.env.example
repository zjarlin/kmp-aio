# VibePocket Server 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务端口映射（主机端口:容器端口8080）
SERVER_PORT=8080

# Ktor 环境: dev 或 prod
KTOR_ENV=prod

# 数据库配置（PostgreSQL）
JDBC_DATABASE_URL=jdbc:postgresql://postgres:5432/vibepocket?user=vibepocket&password=vibepocket123
DATABASE_USERNAME=vibepocket
DATABASE_PASSWORD=vibepocket123
DB_USER=vibepocket
DB_PASSWORD=vibepocket123
DB_PORT=5432

# S3 对象存储配置
S3_ENDPOINT=https://s3.cstcloud.cn
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
